# @testcase 14.d
# @condition Recieve message with a field identifier (tag number) specified but no value.
# @expected Send Reject (session-level) message referencing tag specified without a value. Increment inbound MsgSeqNum. Generate an error condition in test output.

iCONNECT
# logon message and response
I8=FIX.4.135=A34=149=TW4152=<TIME>56=ISLD98=0108=2
E8=FIX.4.19=5835=A34=149=ISLD52=00000000-00:00:0056=TW4198=0108=210=0

#------------------------
# begin message exchange
#------------------------

# heartbeat message with a field identified that doesn't have a value
I8=FIX.4.135=034=249=TW4152=<TIME>56=
# expect a reject
E8=FIX.4.19=9035=334=249=ISLD52=00000000-00:00:0056=TW4145=258=Tag specified without a value (56)10=0

#------------------------
# end message exchange
#------------------------

# logout message and response
I8=FIX.4.135=534=349=TW4152=<TIME>56=ISLD
E8=FIX.4.19=4735=534=349=ISLD52=00000000-00:00:0056=TW4110=0

eDISCONNECT