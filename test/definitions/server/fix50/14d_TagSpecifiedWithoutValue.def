# @testcase 14.d
# @condition Recieve message with a field identifier (tag number) specified but no value.
# @expected Send Reject (session-level) message referencing tag specified without a value. Increment inbound MsgSeqNum. Generate an error condition in test output.

iCONNECT
# logon message and response
I8=FIXT.1.135=A34=149=TW5052=<TIME>56=ISLD98=0108=21137=7
E8=FIXT.1.19=6935=A34=149=ISLD52=00000000-00:00:00.00056=TW5098=0108=21137=710=0

#------------------------
# begin message exchange
#------------------------

# heartbeat message with a field identified that doesn't have a value
I8=FIXT.1.135=034=249=TW5052=<TIME>56=
# expect a reject
E8=FIXT.1.19=10835=334=249=ISLD52=00000000-00:00:00.00056=TW5045=258=Tag specified without a value371=56372=0373=410=0

#------------------------
# end message exchange
#------------------------

# logout message and response
I8=FIXT.1.135=534=349=TW5052=<TIME>56=ISLD
E8=FIXT.1.19=5135=534=349=ISLD52=00000000-00:00:00.00056=TW5010=0

eDISCONNECT